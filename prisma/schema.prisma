generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id         String   @id @db.VarChar(255)
  name       String   @db.VarChar(255)
  username   String   @db.VarChar(255)
  email      String   @unique @db.VarChar(255)
  created_at DateTime @db.Timestamptz(6)
  password   String?
  google_id  String?  @unique @db.VarChar(255)
  avatar_url String?  @db.VarChar(500)

  banner_url           String?   @db.VarChar(500)
  verified             Boolean   @default(false)
  verification_type_id String?   @db.VarChar(255)
  email_verified       Boolean   @default(false)
  email_verified_at    DateTime? @db.Timestamptz(6)

  verification_type         verification_type?         @relation(fields: [verification_type_id], references: [id], onDelete: Cascade, map: "verification_type_id")
  accounts                  accounts[]
  email_verification_tokens email_verification_token[]
  transaction_tags          transaction_tag[]
  sharedAccounts            shared_accounts[]
   taskiti_tasks             taskiti_tasks[]
   taskiti_refresh_tokens    taskiti_refresh_tokens[]
   taskiti_analytics         taskiti_analytics[]
}

model verification_type {
  id       String @id @db.VarChar(255)
  type     String @db.VarChar(255)
  icon_url String @db.VarChar(500)
  users    user[]
}

model email_verification_token {
  id         String   @id @db.VarChar(255)
  user_id    String   @db.VarChar(255)
  token      String   @db.VarChar(6)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @db.Timestamptz(6)

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, token])
  @@index([token])
  @@index([expires_at])
}

model accounts {
  id           String         @id @db.VarChar(255)
  name         String         @db.VarChar(255)
  currency     String         @db.VarChar(10)
  icon         String?        @db.VarChar(255)
  user_id      String         @db.VarChar(255)
  created_at   DateTime       @db.Timestamptz(6)
  updated_at   DateTime       @db.Timestamptz(6)
  deleted_at   DateTime?      @db.Timestamptz(6)
  balance      Decimal        @db.Decimal(10, 2)
  user         user           @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "user_id")
  transactions transactions[]
}

model transactions {
  id            String    @id @db.VarChar(255)
  index_id      BigInt?   @unique
  name          String    @db.VarChar(255)
  amount        Decimal   @db.Decimal(10, 2)
  type          String    @db.VarChar(200)
  account_id    String    @db.VarChar(255)
  issued_at     DateTime  @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime? @db.Timestamptz(6)
  currency_code String?   @db.VarChar(10)
  accounts      accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, map: "account_id")

  tags transaction_tag_assignment[]

  @@index([index_id])
  @@index([account_id])
  @@index([issued_at])
  @@index([updated_at])
  @@index([deleted_at])
  @@index([type])
}

model transaction_tag {
  id         String    @id @db.VarChar(255)
  name       String    @db.VarChar(100)
  slug       String    @db.VarChar(100)
  color      String?   @db.VarChar(20)
  palette    Json?
  user_id    String    @db.VarChar(255)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  user        user                         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignments transaction_tag_assignment[]

  @@unique([user_id, slug])
  @@index([user_id])
  @@index([slug])
  @@index([deleted_at])
}

model transaction_tag_assignment {
  transaction_id String   @db.VarChar(255)
  tag_id         String   @db.VarChar(255)
  assigned_at    DateTime @default(now()) @db.Timestamptz(6)

  transaction     transactions    @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  transaction_tag transaction_tag @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([transaction_id, tag_id])
  @@index([tag_id])
}

model shared_accounts {
  id                    String  @id @db.VarChar(255)
  name                  String  @db.VarChar(255)
  account_id            String  @db.VarChar(255)
  user_id               String  @db.VarChar(255)
  identification_number String? @db.VarChar(255)
  phone_associated      String? @db.VarChar(255)
  email_associated      String? @db.VarChar(255)

  created_at DateTime  @db.Timestamptz(6)
  updated_at DateTime  @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  icon_url   String?   @db.VarChar(255)

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model client_ops {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.VarChar(255)
  client_id   String   @db.VarChar(255)
  entity_type String   @db.VarChar(50)
  result      Json
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, client_id])
  @@index([user_id, created_at])
}

model taskiti_tasks {
  id          String    @id @db.Uuid
  user_id     String    @db.VarChar(255)
  title       String    @db.VarChar(500)
  description String    @default("") @db.Text
  completed   Boolean   @default(false)
  priority    String    @default("medium") @db.VarChar(20)
  tags        String[]
  notes       String    @default("") @db.VarChar(2000)
  created_at  DateTime  @db.Timestamptz(6)
  expires_at  DateTime  @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  version     Int       @default(1)

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([updated_at])
  @@index([user_id, deleted_at])
}

model taskiti_refresh_tokens {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.VarChar(255)
  token_hash String   @db.Text
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model taskiti_analytics {
    id                String    @id @default(uuid()) @db.Uuid
    user_id           String    @db.VarChar(255)
    date              DateTime  @db.Date
    tasks_created     Int       @default(0)
    tasks_completed   Int       @default(0)
    tasks_deleted     Int       @default(0)
    tasks_expired     Int       @default(0)
    priority_low      Int       @default(0)
    priority_medium   Int       @default(0)
    priority_high     Int       @default(0)
    priority_urgent   Int       @default(0)
    avg_completion_hours Float?
    created_at        DateTime  @default(now()) @db.Timestamptz(6)

    user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@unique([user_id, date])
    @@index([user_id, date])
}
